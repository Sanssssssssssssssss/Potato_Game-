{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Spud Arena Server",
      "type": "shell",
      "command": "py",
      "args": [
        "serve.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": {
        "owner": "spud-arena",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Open the game here:"
        }
      }
    }
  ]
}
